# =============================================================================
# VoiceHire — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values.
# Required keys will cause the server to exit on startup if missing.
# =============================================================================

# ── AI/ML API (Premium LLM Provider) ──────────────────────────────────────
# Used for: Rubric synthesis (DeepSeek V4 Pro), probe generation (Qwen3 32B),
#           technical evidence extraction (gpt-4o-mini), resume parsing,
#           job description generation.
# Get a key at: https://aimlapi.com
AIMLAPI_KEY=your_aimlapi_key_here

# ── Featherless AI (Flat-Rate Open-Weight Models) ─────────────────────────
# Used for: Behavioral evidence extraction (Mistral 7B), integrity skepticism
#           (DeepSeek R1). Promo code for hackathon: BOA26
# Get a key at: https://featherless.ai
FEATHERLESS_KEY=your_featherless_key_here

# ── Deepgram (Speech-to-Text & Text-to-Speech) ────────────────────────────
# Used for: Real-time candidate transcription (nova-2 STT), question delivery
#           (aura-2 TTS), filler audio generation.
# Get a key at: https://deepgram.com
DEEPGRAM_KEY=your_deepgram_key_here

# ── Band.ai Platform (Multi-Agent Chat Rooms) ─────────────────────────────
# Used for: Agent orchestration, room creation, message routing.
# Note: The env var is intentionally misspelled 'BRAND' (not 'BAND') —
#       this matches the platform API key label in config.py.
# Get a key at: https://app.band.ai
BRANDAPIKEY=your_band_api_key_here

# ── Band Agent Tokens (Populated by register_agents.py) ───────────────────
# These are automatically generated when you run:
#   python scripts/register_agents.py
# Each agent gets its own API token for scoped access.
# Do NOT manually set these — run the registration script.
BAND_TOKEN_SESSION_BRAIN=
BAND_TOKEN_RUBRIC_SYNTHESIZER=
BAND_TOKEN_VOICE_PERSONA=
BAND_TOKEN_EVIDENCE_CHAIN=
BAND_TOKEN_INTEGRITY_SKEPTIC=
BAND_TOKEN_HIRING_COMMITTEE=

# ── JWT Authentication ────────────────────────────────────────────────────
# Used for: Signing and verifying recruiter session tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here

# ── SMTP (Email Invitations) ──────────────────────────────────────────────
# Used for: Sending interview invitations to candidates.
# Optional — if not configured, email features will be disabled.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@voicehire.ai

# ── Paths & Debug Flags ──────────────────────────────────────────────────
# Override these only if you need custom paths.
# DB_PATH is relative to the project root — used by SQLite.
DB_PATH=db_data/voicehire.db
# Set to "true" for verbose SQLAlchemy logging (development only).
SQL_ECHO=false
# Set to "true" to skip Band.ai agent registration checks at startup.
SKIP_AGENT_CHECK=false
